# Copy to deploy/.env.prod on the droplet and fill in real values.
# deploy/.env.prod is git-ignored and must NEVER be committed.

# Root domain you own; subdomains api./admin./pos. must resolve to the droplet.
DOMAIN=example.com
# Email for Let's Encrypt / Caddy TLS notifications.
ACME_EMAIL=you@example.com

# PostgreSQL credentials (used by the db container and the API connection string).
POSTGRES_USER=posadmin
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=pos

# JWT signing key — MUST be at least 32 characters and kept secret.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_ISSUER=PosApi
JWT_AUDIENCE=PosClients

# Development = auto-migrate + seed demo data + Swagger (easy first bring-up).
# Switch to Production after seeding real data — see docs/hosting-plan.md.
ASPNETCORE_ENVIRONMENT=Development
