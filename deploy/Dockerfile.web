# Multi-stage: build both Vite frontends, then serve them + auto-TLS with Caddy.
# Build context is the repo root.

FROM node:22-alpine AS build
WORKDIR /app/frontend
# VITE_API_URL is baked into the bundle at build time (the API client reads it).
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
COPY frontend/ ./
RUN npm ci && npm run build

FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/frontend/apps/pos-terminal/dist /srv/pos
COPY --from=build /app/frontend/apps/admin-portal/dist /srv/admin
