# Copy to keystore.properties (same folder) and fill in values.
# NEVER commit keystore.properties or the .jks file — both are gitignored.
#
# Generate a release keystore (run once on your local dev machine):
#   keytool -genkeypair -v \
#     -keystore bluraypos-release.jks \
#     -alias bluraypos \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD \
#     -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=BlurayPOS, OU=Terminal, O=Bluray Maldives, L=Male, ST=Maldives, C=MV"
#
# Then set storeFile relative to terminal_app/ (this directory).

storeFile=bluraypos-release.jks
storePassword=CHANGE_ME
keyAlias=bluraypos
keyPassword=CHANGE_ME
