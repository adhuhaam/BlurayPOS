# Local development — committed defaults (localhost ports + Vite /api proxy)
# Override machine-specific values in .env.development.local (gitignored)

# Empty = same-origin /api via Vite dev proxy → localhost API (DEV_API_PORT or 5147)
VITE_API_URL=

VITE_MARKETING_URL=http://localhost:5175
VITE_OFFICE_URL=http://localhost:5174
VITE_POS_URL=http://localhost:5173
VITE_COUPONS_URL=http://localhost:5176
VITE_MENU_URL=http://localhost:5178
VITE_ORDER_URL=http://localhost:5177
