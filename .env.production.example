# BlurayPOS production environment — copy to .env on the server and fill in secrets.
# Generate secrets: openssl rand -base64 48
#
# Frontend Vite URLs (subdomains) live in frontend/env/.env.production (committed).
# This file is backend-only: DB, JWT, CORS, systemd — never mix with local dev .env on your PC.

POSTGRES_USER=pos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=pos_prod

JWT_SECRET=CHANGE_ME_MIN_32_CHAR_RANDOM_STRING_FOR_JWT_SIGNING

# Domain
DOMAIN=bluraymaldives.site
API_URL=https://api.bluraymaldives.site
OFFICE_URL=https://office.bluraymaldives.site
POS_URL=https://pos.bluraymaldives.site

# ASP.NET Core (systemd reads these from EnvironmentFile)
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000
API_PORT=5000

ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=pos_prod;Username=pos;Password=CHANGE_ME_STRONG_DB_PASSWORD
ConnectionStrings__Redis=127.0.0.1:6379

Jwt__Secret=CHANGE_ME_MIN_32_CHAR_RANDOM_STRING_FOR_JWT_SIGNING
Jwt__Issuer=PosApi
Jwt__Audience=PosClients

Cors__Origins__0=https://bluraymaldives.site
Cors__Origins__1=https://office.bluraymaldives.site
Cors__Origins__2=https://pos.bluraymaldives.site
Cors__Origins__3=https://coupons.bluraymaldives.site
Cors__Origins__4=https://menu.bluraymaldives.site
Cors__Origins__5=https://order.bluraymaldives.site
Cors__Origins__6=https://hr.bluraymaldives.site

# Certbot email for Let's Encrypt
CERTBOT_EMAIL=your-email@example.com
